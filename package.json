{
  "name": "accessibility-friction-overlay-ecwid",
  "version": "1.0.0",
  "description": "Static Ecwid deployment for Accessibility Friction Overlay with no backend, database, or Redis dependency.",
  "scripts": {
    "build": "node scripts/render-publishing-pages.mjs && node scripts/build.mjs",
